# Copy to .env and fill in.
# The benchmark needs the customer simulator + the customer-facing actor.

# Anthropic (used by the customer simulator + Planner's CoT reasoning step)
ANTHROPIC_API_KEY=

# Google AI Studio (used by the customer-facing actor — Gemini 2.5 Pro)
GEMINI_API_KEY_1=

# Optional — voyage embeddings for the simulator's similarity check
# (falls back to word-overlap if absent)
VOYAGE_API_KEY=

# Optional — only needed for the Strategist arm (Agent Knowledge Graph)
# LIGHTRAG_API_URL=
# LIGHTRAG_API_KEY=

# Feature flags (defaults shown)
POC_SIM_V2_REFERENCE=on
POC_PLANNER_GATES=on
